{
    "number": 102,
    "name": "سُورَةُ التَّكَاثُرِ",
    "englishName": "At-Takaathur",
    "englishNameTranslation": "Competition",
    "revelationType": "Meccan",
    "tamilName": "அத்-தகாஸுர்",
    "tamilNameTranslation": "பேராசை",
    "revelationTypeTamil": "மக்கீ",
    "numberOfAyahs": 8,
    "ayahs": [
        {
            "number": 6169,
            "text": "أَلْهَاكُمُ التَّكَاثُرُ",
            "tamilTransliteration": "அல் ஹாகு முத் தகதுர்",
            "tamilTranslation": "செல்வத்தைப பெருக்கும் ஆசை உங்களை (அல்லாஹ்வை விட்டும்) பராக்காக்கி விட்டது- (திருப்பிவிட்டது).",
            "numberInSurah": 1,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 544,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6170,
            "text": "حَتَّىٰ زُرْتُمُ الْمَقَابِرَ",
            "tamilTransliteration": "ஹத்த Zஜுர்துமுல்-மகாBபிர்",
            "tamilTranslation": "நீங்கள் மண்ணறைகளைச் சந்திக்கும் வரை.",
            "numberInSurah": 2,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 544,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6171,
            "text": "كَلَّا سَوْفَ تَعْلَمُونَ",
            "tamilTransliteration": "கல்லா ஸவ்Fப தஃலமூன்",
            "tamilTranslation": "அவ்வாறில்லை, விரைவில் (அதன் பலனை) நீங்கள் அறிந்து கொள்வீர்கள்.",
            "numberInSurah": 3,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 544,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6172,
            "text": "ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ",
            "tamilTransliteration": "தும்ம கல்லா ஸவ்Fப தஃலமூன்",
            "tamilTranslation": "பின்னர் அவ்வாறல்ல, விரைவில் (அதன் பலனை) நீங்கள் அறிந்து கொள்வீர்கள்.",
            "numberInSurah": 4,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 544,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6173,
            "text": "كَلَّا لَوْ تَعْلَمُونَ عِلْمَ الْيَقِينِ",
            "tamilTransliteration": "கல்லா லவ் தஃலமூன 'இல்மல் யகீன்",
            "tamilTranslation": "அவ்வாறல்ல - மெய்யான அறிவைக் கொண்டறிந்திருப்பீர்களானால் (அந்த ஆசை உங்களைப் பராக்காக்காது).",
            "numberInSurah": 5,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 544,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6174,
            "text": "لَتَرَوُنَّ الْجَحِيمَ",
            "tamilTransliteration": "லதர-வுன் னல் ஜஹீம்",
            "tamilTranslation": "நிச்சயமாக (அவ்வாசையால்) நீங்கள் நரகத்தைப் பார்ப்பீர்கள்.",
            "numberInSurah": 6,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 544,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6175,
            "text": "ثُمَّ لَتَرَوُنَّهَا عَيْنَ الْيَقِينِ",
            "tamilTransliteration": "தும்ம லதர வுன்னஹா 'அய்னல் யகீன்",
            "tamilTranslation": "பின்னும், நீங்கள் அதை உறுதியாகக் கண்ணால் பார்ப்பீர்கள்.",
            "numberInSurah": 7,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 544,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6176,
            "text": "ثُمَّ لَتُسْأَلُنَّ يَوْمَئِذٍ عَنِ النَّعِيمِ",
            "tamilTransliteration": "தும்ம லதுஸ் அலுன்ன யவ்ம-இதின் 'அனின் ன'ஈம்",
            "tamilTranslation": "பின்னர் அந்நாளில் (இம்மையில் உங்களுக்கு அளிக்கப்பட்டிருந்த) அருட் கொடைகளைப் பற்றி நிச்சயமாக நீங்கள் கேட்கப்படுவீர்கள்.",
            "numberInSurah": 8,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 544,
            "hizbQuarter": 240,
            "sajda": false
        }
    ]
}
