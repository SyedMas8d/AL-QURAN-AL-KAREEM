{
    "number": 93,
    "name": "سُورَةُ الضُّحَىٰ",
    "englishName": "Ad-Dhuhaa",
    "englishNameTranslation": "The Morning Hours",
    "tamilName": "ளுஹா",
    "tamilNameTranslation": "முற்பகல்",
    "revelationTypeTamil": "மக்கீ",
    "revelationType": "Meccan",
    "numberOfAyahs": 11,
    "ayahs": [
        {
            "number": 6080,
            "text": "وَالضُّحَىٰ",
            "tamilTransliteration": "வள் ளுஹா",
            "tamilTranslation": "முற்பகல் மீது சத்தியமாக",
            "numberInSurah": 1,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 535,
            "hizbQuarter": 238,
            "sajda": false
        },
        {
            "number": 6081,
            "text": "وَاللَّيْلِ إِذَا سَجَىٰ",
            "tamilTransliteration": "வல் லய்லி இத ஸஜா",
            "tamilTranslation": "மறைத்துக் கொள்ளும் (இருண்ட) இரவின் மீது சத்தியமாக!",
            "numberInSurah": 2,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 535,
            "hizbQuarter": 238,
            "sajda": false
        },
        {
            "number": 6082,
            "text": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
            "tamilTransliteration": "ம வத் த'அக ரBப்Bபுக வ ம கலா",
            "tamilTranslation": "உம்முடைய இறைவன் உம்மைக் கை விடவுமில்லை; அவன் (உம்மை) வெறுக்கவுமில்லை.",
            "numberInSurah": 3,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 535,
            "hizbQuarter": 238,
            "sajda": false
        },
        {
            "number": 6083,
            "text": "وَلَلْآخِرَةُ خَيْرٌ لَكَ مِنَ الْأُولَىٰ",
            "tamilTransliteration": "வலல்ஆகிரது கய்ருல் லக மினல்-ஊலா",
            "tamilTranslation": "(ஒவ்வொரு நாளும் உமது) பிந்திய நிலைமை, முந்திய நிலைமையை விட நிச்சயமாக மிக்க மேலானதாக இருக்கிறது.",
            "numberInSurah": 4,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 535,
            "hizbQuarter": 238,
            "sajda": false
        },
        {
            "number": 6084,
            "text": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰ",
            "tamilTransliteration": "வ ல ஸவ்Fப யுஃதீக ரBப்Bபுக Fபதர்ளா",
            "tamilTranslation": "உமது இறைவன் மேலும் (பல உயர் பதவிகளை) உமக்கு அளிப்பான். (அவற்றைக் கொண்டு) நீர் திருப்தியடைவீர்.",
            "numberInSurah": 5,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 535,
            "hizbQuarter": 238,
            "sajda": false
        },
        {
            "number": 6085,
            "text": "أَلَمْ يَجِدْكَ يَتِيمًا فَآوَىٰ",
            "tamilTransliteration": "அலம் ய ஜித்க யதீமன் Fப ஆவா",
            "tamilTranslation": "(நபியே!) அவன் உம்மை அநாதையாகக் கண்டு, அப்பால் (உமக்குப்) புகலிடமளிக்கவில்லையா?",
            "numberInSurah": 6,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 535,
            "hizbQuarter": 238,
            "sajda": false
        },
        {
            "number": 6086,
            "text": "وَوَجَدَكَ ضَالًّا فَهَدَىٰ",
            "tamilTransliteration": "வ வ ஜதக ளால் லன் Fபஹதா",
            "tamilTranslation": "இன்னும், உம்மை வழியற்றவராகக் கண்டு அவன், (உம்மை) நேர்வழியில் செலுத்தினான்.",
            "numberInSurah": 7,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 535,
            "hizbQuarter": 238,
            "sajda": false
        },
        {
            "number": 6087,
            "text": "وَوَجَدَكَ عَائِلًا فَأَغْنَىٰ",
            "tamilTransliteration": "வ வ ஜதக 'ஆ-இலன் Fப அக்னா",
            "tamilTranslation": "மேலும், அவன் உம்மைத் தேவையுடையவராகக்கண்டு, (உம்மைச் செல்வத்தால்) தேவையில்லாதவராக்கினான்.",
            "numberInSurah": 8,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 535,
            "hizbQuarter": 238,
            "sajda": false
        },
        {
            "number": 6088,
            "text": "فَأَمَّا الْيَتِيمَ فَلَا تَقْهَرْ",
            "tamilTransliteration": "Fப அம் மல் யதீம Fபல தக்ஹர்",
            "tamilTranslation": "எனவே, நீர் அநாதையைக் கடிந்து கொள்ளாதீர்.",
            "numberInSurah": 9,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 535,
            "hizbQuarter": 238,
            "sajda": false
        },
        {
            "number": 6089,
            "text": "وَأَمَّا السَّائِلَ فَلَا تَنْهَرْ",
            "tamilTransliteration": "வ அம் மஸ் ஸா-இல Fபல தன்ஹர்",
            "tamilTranslation": "யாசிப்போரை விரட்டாதீர்.",
            "numberInSurah": 10,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 535,
            "hizbQuarter": 238,
            "sajda": false
        },
        {
            "number": 6090,
            "text": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
            "tamilTransliteration": "வ அம்ம Bபி னிஃமதி ரBப்Bபிக Fபஹத் தித்",
            "tamilTranslation": "(உம்மீது புரிந்துள்ள) உமது இறைவனின் அருளைப் (பிறருக்கு) அறிவித்து (அவனுக்கு நன்றி செலுத்தி)க் கொண்டிருப்பீராக!",
            "numberInSurah": 11,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 535,
            "hizbQuarter": 238,
            "sajda": false
        }
    ]
}
