{
    "number": 100,
    "name": "سُورَةُ العَادِيَاتِ",
    "englishName": "Al-Aadiyaat",
    "englishNameTranslation": "The Chargers",
    "revelationType": "Meccan",
    "tamilName": "அல்-ஆதியாத்தி",
    "tamilNameTranslation": "வேகமாகச் செல்லுபவை",
    "revelationTypeTamil": "மக்கீ",
    "numberOfAyahs": 11,
    "ayahs": [
        {
            "number": 6147,
            "text": "وَالْعَادِيَاتِ ضَبْحًا",
            "tamilTransliteration": "வல்'ஆதி யாதி ளBப்ஹா",
            "tamilTranslation": "மூச்சிரைக்கும் சப்தத்தோடு (போர்க்களத்தில் எதிரிகளைத்தாக்க) அதிவேகமாக ஓடுகின்றவற்றின் (குதிரைகளின்) மீது சத்தியமாக!",
            "numberInSurah": 1,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 542,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6148,
            "text": "فَالْمُورِيَاتِ قَدْحًا",
            "tamilTransliteration": "Fபல் மூரி யாதி கத்ஹா",
            "tamilTranslation": "பின்னர், (செல்லும் வேகத்தில் அவற்றின் குளம்புகள் கற்களில் மோத) தீப்பொறியை பறக்கச் செய்பவற்றின் மீதும் சத்தியமாக!",
            "numberInSurah": 2,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 542,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6149,
            "text": "فَالْمُغِيرَاتِ صُبْحًا",
            "tamilTransliteration": "Fபல் முகீராதி ஸுBப்ஹா",
            "tamilTranslation": "பிறகு, அதிகாலையில் வேகமாக (எதிரிகள் மீது) பாய்ந்து செல்பவற்றின் மீதும் சத்தியமாக!",
            "numberInSurah": 3,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 542,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6150,
            "text": "فَأَثَرْنَ بِهِ نَقْعًا",
            "tamilTransliteration": "Fப அதர்ன Bபிஹீ னக்'ஆ",
            "tamilTranslation": "(அதிகாலையில் அவ்வாறு அதி வேகமாகச் செல்லும்போது) அதனால் புழுதியை கிளப்புகின்றவற்றின் மீதும் சத்தியமாக!",
            "numberInSurah": 4,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 542,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6151,
            "text": "فَوَسَطْنَ بِهِ جَمْعًا",
            "tamilTransliteration": "Fபவ ஸத்ன Bபிஹீ ஜம்'ஆ",
            "tamilTranslation": "பின்னர் (எதிரிகளின்) படைகளுக்கு மத்தியில் செல்கின்றவற்றின் மீதும் சத்தியமாக!",
            "numberInSurah": 5,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 542,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6152,
            "text": "إِنَّ الْإِنْسَانَ لِرَبِّهِ لَكَنُودٌ",
            "tamilTransliteration": "இன்னல்-இன்ஸான லிரBப்Bபிஹீ லகனூத்",
            "tamilTranslation": "நிச்சயமாக மனிதன் தன் இரட்சகனுக்கு நன்றி கெட்டவனாகவே இருக்கின்றான்.",
            "numberInSurah": 6,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 542,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6153,
            "text": "وَإِنَّهُ عَلَىٰ ذَٰلِكَ لَشَهِيدٌ",
            "tamilTransliteration": "வ இன்னஹு 'அலா தாலிக ல ஷஹீத்",
            "tamilTranslation": "மேலும், நிச்சயமாக அவனே இதற்கு சாட்சியாகவும் இருக்கின்றான்.",
            "numberInSurah": 7,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 542,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6154,
            "text": "وَإِنَّهُ لِحُبِّ الْخَيْرِ لَشَدِيدٌ",
            "tamilTransliteration": "வ இன்னஹு லிஹுBப்Bபில் கய்ரி ல ஷதீத்",
            "tamilTranslation": "இன்னும், நிச்சயமாக அவன் பொருளை நேசிப்பதில் அளவு கடந்தே இருக்கின்றான்.",
            "numberInSurah": 8,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 542,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6155,
            "text": "۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِي الْقُبُورِ",
            "tamilTransliteration": "அFபல யஃலமு இத Bபுஃதிர ம Fபில்குBபூர்",
            "tamilTranslation": "அவன் அறிந்துகொள்ள வேண்டாமா? மண்ணறைகளிலுள்ளவை (எழுப்பப்பட்டு) வெளியேற்றப்பட்டுவிடும்போது",
            "numberInSurah": 9,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 542,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6156,
            "text": "وَحُصِّلَ مَا فِي الصُّدُورِ",
            "tamilTransliteration": "வ ஹுஸ்ஸில மா Fபிஸ் ஸுதூர்",
            "tamilTranslation": "இதயங்களிலுள்ளவையும் வெளியாக்கப்பட்டுவிடும்போது,",
            "numberInSurah": 10,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 542,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6157,
            "text": "إِنَّ رَبَّهُمْ بِهِمْ يَوْمَئِذٍ لَخَبِيرٌ",
            "tamilTransliteration": "இன்ன ரBப்Bபஹும் Bபிஹிம் யவ்ம 'இதின் லகBபீர்",
            "tamilTranslation": "நிச்சயமாக அவர்களின் இரட்சகன், அவர்களைப்பற்றி அந்நாளில் நன்கு உணர்பவன் (ஆகவே, நன்மைக்கு நற்கூலியும், தீமைக்கு தண்டனையும் வழங்குவான்).",
            "numberInSurah": 11,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 542,
            "hizbQuarter": 240,
            "sajda": false
        }
    ]
}
