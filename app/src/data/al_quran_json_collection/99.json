{
    "number": 99,
    "name": "سُورَةُ الزَّلۡزَلَةِ",
    "englishName": "Az-Zalzala",
    "englishNameTranslation": "The Earthquake",
    "revelationType": "Medinan",
    "tamilName": "ஜில்ஜால்",
    "tamilNameTranslation": "அதிர்ச்சி",
    "revelationTypeTamil": "மக்கீ",
    "numberOfAyahs": 8,
    "ayahs": [
        {
            "number": 6139,
            "text": "إِذَا زُلْزِلَتِ الْأَرْضُ زِلْزَالَهَا",
            "tamilTransliteration": "இதா Zஜுல் Zஜிலதில் அர்ளு Zஜில் Zஜாலஹா",
            "tamilTranslation": "பூமி பெரும் அதிர்ச்சியாக - அதிர்ச்சி அடையும் போது",
            "numberInSurah": 1,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 541,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6140,
            "text": "وَأَخْرَجَتِ الْأَرْضُ أَثْقَالَهَا",
            "tamilTransliteration": "வ அக் ரஜதில் அர்ளு அத்காலஹா",
            "tamilTranslation": "இன்னும், பூமி தன் சுமைகளை வெளிப்படுத்தும் போது",
            "numberInSurah": 2,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 541,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6141,
            "text": "وَقَالَ الْإِنْسَانُ مَا لَهَا",
            "tamilTransliteration": "வ காலல் இன்ஸானு ம லஹா",
            "tamilTranslation": "“அதற்கு என்ன நேர்ந்தது?” என்று மனிதன் கேட்கும் போது",
            "numberInSurah": 3,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 541,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6142,
            "text": "يَوْمَئِذٍ تُحَدِّثُ أَخْبَارَهَا",
            "tamilTransliteration": "யவ்மா இதின் துஹத்திது அக்Bபாரஹா",
            "tamilTranslation": "அந்நாளில், அது தன் செய்திகளை அறிவிக்கும்.",
            "numberInSurah": 4,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 541,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6143,
            "text": "بِأَنَّ رَبَّكَ أَوْحَىٰ لَهَا",
            "tamilTransliteration": "Bபி-அன்ன ரBப்Bபக அவ்ஹா லஹா",
            "tamilTranslation": "(அவ்வாறு அறிவிக்குமாறு) உம்முடைய இறைவன் அதற்கு வஹீ மூலம் அறிவித்ததனால்.",
            "numberInSurah": 5,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 541,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6144,
            "text": "يَوْمَئِذٍ يَصْدُرُ النَّاسُ أَشْتَاتًا لِيُرَوْا أَعْمَالَهُمْ",
            "tamilTransliteration": "யவ்ம இதி(ன்)ய் யஸ் துருன் னாஸு அஷ் தாதல் லியுரவ் அஃமாலஹும்",
            "tamilTranslation": "அந்நாளில், மக்கள் தங்கள் வினைகள் காண்பிக்கப்படும் பொருட்டு, பல பிரிவினர்களாகப் பிரிந்து வருவார்கள்.",
            "numberInSurah": 6,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 541,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6145,
            "text": "فَمَنْ يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًا يَرَهُ",
            "tamilTransliteration": "Fபமய்ய் யஃமல் மிஃத்கால தர்ரதின் கய் ரய்ய்-யரஹ்",
            "tamilTranslation": "எனவே, எவர் ஓர் அணுவளவு நன்மை செய்திருந்தாலும் அத(ற்குரிய பல)னை அவர் கண்டு கொள்வார்.",
            "numberInSurah": 7,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 541,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6146,
            "text": "وَمَنْ يَعْمَلْ مِثْقَالَ ذَرَّةٍ شَرًّا يَرَهُ",
            "tamilTransliteration": "வ மய்ய்-யஃமல் மிஃத்கால தர்ரதின் ஷர்ரய்ய்-யரஹ்",
            "tamilTranslation": "அன்றியும், எவன் ஓர் அணுவளவு தீமை செய்திருந்தாலும், அ(தற்குரிய பல)னையும் அவன் கண்டு கொள்வான்.",
            "numberInSurah": 8,
            "juz": 30,
            "manzil": 7,
            "page": 599,
            "ruku": 541,
            "hizbQuarter": 239,
            "sajda": false
        }
    ]
}
