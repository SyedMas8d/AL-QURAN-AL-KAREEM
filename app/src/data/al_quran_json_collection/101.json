{
    "number": 101,
    "name": "سُورَةُ القَارِعَةِ",
    "englishName": "Al-Qaari'a",
    "englishNameTranslation": "The Calamity",
    "revelationType": "Meccan",
    "tamilName": "அல்-காரி'அஹ்",
    "tamilNameTranslation": "திடுக்கிடச் செய்யும் நிகழ்ச்சி",
    "revelationTypeTamil": "மக்கீ",
    "numberOfAyahs": 11,
    "ayahs": [
        {
            "number": 6158,
            "text": "الْقَارِعَةُ",
            "tamilTransliteration": "அல் காரி'அஹ்",
            "tamilTranslation": "திடுக்கிடச் செய்யும் (நிகழ்ச்சி).",
            "numberInSurah": 1,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 543,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6159,
            "text": "مَا الْقَارِعَةُ",
            "tamilTransliteration": "மல் காரிஅஹ்",
            "tamilTranslation": "திடுக்கிடச் செய்யும் (நிகழ்ச்சி) என்ன?",
            "numberInSurah": 2,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 543,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6160,
            "text": "وَمَا أَدْرَاكَ مَا الْقَارِعَةُ",
            "tamilTransliteration": "வமா அத்ராக மல் காரி'அஹ்",
            "tamilTranslation": "திடுக்கிடச் செய்யும் (நிகழ்ச்சி) என்ன வென்று உமக்கு எது அறிவித்தது?",
            "numberInSurah": 3,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 543,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6161,
            "text": "يَوْمَ يَكُونُ النَّاسُ كَالْفَرَاشِ الْمَبْثُوثِ",
            "tamilTransliteration": "யவ்ம ய கூனுன் னாஸு கல் Fபராஷில் மBப்தூத்",
            "tamilTranslation": "அந்நாளில் சிதறடிக்கப்படட ஈசல்களைப் போன்று மனிதர்கள் ஆகிவிடுவார்கள்.",
            "numberInSurah": 4,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 543,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6162,
            "text": "وَتَكُونُ الْجِبَالُ كَالْعِهْنِ الْمَنْفُوشِ",
            "tamilTransliteration": "வ த கூனுல் ஜிBபாலு கல் 'இஹ்னில் மன்Fபூஷ்",
            "tamilTranslation": "மேலும், மலைகள் கொட்டப்பட்ட பஞ்சைப் போன்று ஆகிவிடும்.",
            "numberInSurah": 5,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 543,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6163,
            "text": "فَأَمَّا مَنْ ثَقُلَتْ مَوَازِينُهُ",
            "tamilTransliteration": "Fப-அம்மா மன் தகுலத் ம-வாZஜீனுஹ்",
            "tamilTranslation": "எனவே, (அந்நாளில்) எவருடைய (நன்மையின்) நிறை கனத்ததோ-",
            "numberInSurah": 6,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 543,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6164,
            "text": "فَهُوَ فِي عِيشَةٍ رَاضِيَةٍ",
            "tamilTransliteration": "Fபஹுவ Fபீ 'இஷதிர் ராளியஹ்",
            "tamilTranslation": "அவர் திருப்தி பொருந்திய வாழ்வில் இருப்பார்.",
            "numberInSurah": 7,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 543,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6165,
            "text": "وَأَمَّا مَنْ خَفَّتْ مَوَازِينُهُ",
            "tamilTransliteration": "வ அம்ம மன் கFப்Fபத் ம-வாZஜீனுஹ்",
            "tamilTranslation": "ஆனால் எவனுடைய (நன்மையின்) நிறை இலேசாக இருக்கிறதோ-",
            "numberInSurah": 8,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 543,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6166,
            "text": "فَأُمُّهُ هَاوِيَةٌ",
            "tamilTransliteration": "Fப-உம்முஹு ஹாவியஹ்",
            "tamilTranslation": "அவன் தங்குமிடம் “ஹாவியா” தான்.",
            "numberInSurah": 9,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 543,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6167,
            "text": "وَمَا أَدْرَاكَ مَا هِيَهْ",
            "tamilTransliteration": "வமா அத்ராக மா ஹியஹ்",
            "tamilTranslation": "இன்னும் (“ஹாவியா”) என்ன என்று உமக்கு அறிவித்தது எது?",
            "numberInSurah": 10,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 543,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6168,
            "text": "نَارٌ حَامِيَةٌ",
            "tamilTransliteration": "னாருன் ஹாமியஹ்",
            "tamilTranslation": "அது சுட்டெரிக்கும் (நரகத்தின்) தீக்கிடங்காகும்.",
            "numberInSurah": 11,
            "juz": 30,
            "manzil": 7,
            "page": 600,
            "ruku": 543,
            "hizbQuarter": 240,
            "sajda": false
        }
    ]
}
