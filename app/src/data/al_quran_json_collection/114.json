            "page": 604,
            "ruku": 556,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6234,
            "text": "مِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِ",
            "tamilTransliteration": "மின் ஷர்ரில் வஸ்வாஸில் கன்னாஸ்",
            "tamilTranslation": "பதுங்கியிருந்து வீண் சந்தேகங்களை உண்டாக்குபவனின் தீங்கை விட்டும் (இறைவனிடத்தில் நான் காவல் தேடுகிறேன்).",
            "numberInSurah": 4,
            "juz": 30,
            "manzil": 7,
            "page": 604,
            "ruku": 556,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6235,
            "text": "الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ",
            "tamilTransliteration": "அல்லதீ யுவஸ்விஸு Fபீ ஸுதூரின் னாஸ்",
            "tamilTranslation": "அவன் மனிதர்களின் இதயங்களில் வீண் சந்தேகங்களை உண்டாக்குகிறான்.",
            "numberInSurah": 5,
