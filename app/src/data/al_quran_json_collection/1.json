{
    "number": 1,
    "name": "سُورَةُ ٱلْفَاتِحَةِ",
    "englishName": "Al-Faatiha",
    "englishNameTranslation": "The Opening",
    "tamilName": "அல்‌-ஃபாத்திஹா",
    "tamilNameTranslation": "தொடக்கம்‌",
    "revelationType": "Meccan",
    "revelationTypeTamil": "மக்கீ",
    "numberOfAyahs": 7,
    "ayahs": [
        {
            "number": 1,
            "text": "﻿بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ",
            "tamilTransliteration": "பிஸ்மில்லாஹிர் ரஹ்மானிர் ரஹீம்",
            "tamilTranslation": "அளவற்ற அருளாளனும், நிகரற்ற அன்புடையோனுமாகிய அல்லாஹ்வின் திருப்பெயரால்(துவங்குகிறேன்)",
            "numberInSurah": 1,
            "juz": 1,
            "manzil": 1,
            "page": 1,
            "ruku": 1,
            "hizbQuarter": 1,
            "sajda": false
        },
        {
            "number": 2,
            "text": "الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ",
            "tamilTransliteration": "அல்ஹம்து லில்லாஹி ரBப்Bபில் 'ஆலமீன்",
            "tamilTranslation": "அனைத்து புகழும், அகிலங்கள் எல்லாவற்றையும் படைத்து வளர்த்துப் பரிபக்குவப்படுத்தும் (நாயனான) அல்லாஹ்வுக்கே ஆகும்.",
            "numberInSurah": 2,
            "juz": 1,
            "manzil": 1,
            "page": 1,
            "ruku": 1,
            "hizbQuarter": 1,
            "sajda": false
        },
        {
            "number": 3,
            "text": "الرَّحْمَٰنِ الرَّحِيمِ",
            "tamilTransliteration": "அர்ரஹ்மானிர் ரஹீம்",
            "tamilTranslation": "(அவன்) அளவற்ற அருளாளன் நிகரற்ற அன்புடையோன்.",
            "numberInSurah": 3,
            "juz": 1,
            "manzil": 1,
            "page": 1,
            "ruku": 1,
            "hizbQuarter": 1,
            "sajda": false
        },
        {
            "number": 4,
            "text": "مَالِكِ يَوْمِ الدِّينِ",
            "tamilTransliteration": "மாலிகி யவ்மித்-தீன்",
            "tamilTranslation": "(அவனே நியாயத்) தீர்ப்பு நாளின் அதிபதி(யும் ஆவான்).",
            "numberInSurah": 4,
            "juz": 1,
            "manzil": 1,
            "page": 1,
            "ruku": 1,
            "hizbQuarter": 1,
            "sajda": false
        },
        {
            "number": 5,
            "text": "إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ",
            "tamilTransliteration": "இய்யாக னஃBபுது வ இய்யாக னஸ்த'ஈன்",
            "tamilTranslation": "(இறைவா!)உன்னையே நாங்கள் வணங்குகிறோம்; உன்னிடமே நாங்கள் உதவியும் தேடுகிறோம்.",
            "numberInSurah": 5,
            "juz": 1,
            "manzil": 1,
            "page": 1,
            "ruku": 1,
            "hizbQuarter": 1,
            "sajda": false
        },
        {
            "number": 6,
            "text": "اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ",
            "tamilTransliteration": "இஹ்தினஸ்-ஸிராதல்-முஸ்தகீம்",
            "tamilTranslation": "நீ எங்களை நேர்வழியில் நடத்துவாயாக!",
            "numberInSurah": 6,
            "juz": 1,
            "manzil": 1,
            "page": 1,
            "ruku": 1,
            "hizbQuarter": 1,
            "sajda": false
        },
        {
            "number": 7,
            "text": "صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ",
            "tamilTransliteration": "ஸிராதல்-லதீன அன்'அம்த 'அலய்ஹிம் கய்ரில்-மக்ளூBபி 'அலய்ஹிம் வ லள்-ளால்லீன்",
            "tamilTranslation": "(அது) நீ எவர்களுக்கு அருள் புரிந்தாயோ அவ்வழி. (அது) உன் கோபத்திற்கு ஆளானோர் வழியுமல்ல நெறி தவறியோர் வழியுமல்ல.",
            "numberInSurah": 7,
            "juz": 1,
            "manzil": 1,
            "page": 1,
            "ruku": 1,
            "hizbQuarter": 1,
            "sajda": false
        }
    ]
}
