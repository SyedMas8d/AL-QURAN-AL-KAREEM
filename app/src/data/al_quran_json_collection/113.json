    "ayahs": [
        {
            "number": 6226,
            "text": "قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ",
            "tamilTransliteration": "குல் அ'ஊது Bபி ரBப்Bபில்-Fபலக்",
            "tamilTranslation": "(நபியே!) நீர் சொல்வீராக: அதிகாலையின் இறைவனிடத்தில் நான் காவல் தேடுகிறேன்.",
            "numberInSurah": 1,
            "juz": 30,
            "manzil": 7,
            "page": 604,
            "ruku": 555,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6227,
            "text": "مِنْ شَرِّ مَا خَلَقَ",
            "tamilTransliteration": "மின் ஷர்ரி மா கலக்",
            "tamilTranslation": "அவன் படைத்தவற்றின் தீங்கை விட்டும்",
            "numberInSurah": 2,
            "juz": 30,
            "manzil": 7,
            "page": 604,
            "ruku": 555,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6228,
            "text": "وَمِنْ شَرِّ غَاسِقٍ إِذَا وَقَبَ",
            "tamilTransliteration": "வ மின் ஷர்ரி காஸிகின் இதா வகBப்",
            "tamilTranslation": "இருள் பரவும் போது ஏற்படும் இரவின் தீங்கை விட்டும்",
            "numberInSurah": 3,
            "juz": 30,
            "manzil": 7,
            "page": 604,
            "ruku": 555,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6229,
            "text": "وَمِنْ شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ",
            "tamilTransliteration": "வ மின் ஷர்ரின்-னFப்Fபா-தாதி Fபில் 'உகத்",
            "tamilTranslation": "இன்னும், முடிச்சுகளில் (மந்திரித்து) ஊதும் பெண்களின் தீங்கை விட்டும்",
            "numberInSurah": 4,
            "juz": 30,
            "manzil": 7,
            "page": 604,
            "ruku": 555,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6230,
            "text": "وَمِنْ شَرِّ حَاسِدٍ إِذَا حَسَدَ",
            "tamilTransliteration": "வ மின் ஷர்ரி ஹாஸிதின் இதா ஹஸத்",
            "tamilTranslation": "பொறாமைக்காரன் பொறாமை கொள்ளும் போதுண்டாகும் தீங்கை விட்டும் (காவல் தேடுகிறேன்).",
