            "page": 596,
            "ruku": 536,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6097,
            "text": "فَإِذَا فَرَغْتَ فَانْصَبْ",
            "tamilTransliteration": "Fப இத Fபரக் த Fபன்ஸBப்",
            "tamilTranslation": "ஆகவே, (மார்க்கப் பிரச்சாரத்திலிருந்து) நீர் விடுபட்டதும், (இறைவனை வணங்குவதற்கு) சிரத்தை எடுப்பீராக.",
            "numberInSurah": 7,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 536,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6098,
            "text": "وَإِلَىٰ رَبِّكَ فَارْغَبْ",
            "tamilTransliteration": "வ இலா ரBப்Bபிக Fபர் கBப்",
            "tamilTranslation": "மேலும், (துன்பத்திலும் இன்பத்திலும்) உமது இறைவனையே நீர் நோக்கி நிற்பீராக!",
