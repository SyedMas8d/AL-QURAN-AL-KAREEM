{
    "number": 94,
    "name": "سُورَةُ الشَّرۡحِ",
    "englishName": "Ash-Sharh",
    "englishNameTranslation": "The Consolation",
    "revelationType": "Meccan",
    "tamilName": "அலம் நஷ்ரஹ்",
    "tamilNameTranslation": "விரிவாக்கல்",
    "revelationTypeTamil": "மக்கீ",
    "numberOfAyahs": 8,
    "ayahs": [
        {
            "number": 6091,
            "text": "أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ",
            "tamilTransliteration": "அலம் னஷ்ரஹ் லக ஸத்ரக்",
            "tamilTranslation": "(நபியே!) உமது உள்ளத்தை நாம் உமக்கு விரிவாக்கவில்லையா?",
            "numberInSurah": 1,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 536,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6092,
            "text": "وَوَضَعْنَا عَنْكَ وِزْرَكَ",
            "tamilTransliteration": "வ வ ளஃன 'அன்க விZஜ்ரக்",
            "tamilTranslation": "மேலும், உமது சுமையையும் உம்மைவிட்டும் நாம் இறக்கிவிட்டோம்.",
            "numberInSurah": 2,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 536,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6093,
            "text": "الَّذِي أَنْقَضَ ظَهْرَكَ",
            "tamilTransliteration": "அல்லதீ அன்கள ளஹ்ரக்",
            "tamilTranslation": "அது உம் முதுகை முறித்துக் கொண்டிருந்தது.",
            "numberInSurah": 3,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 536,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6094,
            "text": "وَرَفَعْنَا لَكَ ذِكْرَكَ",
            "tamilTransliteration": "வ ரFபஃன லக திக்ரக்",
            "tamilTranslation": "மேலும், நாம் உமக்காக உம்முடைய புகழை மேலோங்கச் செய்தோம்.",
            "numberInSurah": 4,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 536,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6095,
            "text": "فَإِنَّ مَعَ الْعُسْرِ يُسْرًا",
            "tamilTransliteration": "Fப இன்ன ம'அல் உஸ்ரி யுஸ்ரா",
            "tamilTranslation": "ஆதலின் நிச்சயமாக துன்பத்துடன் இன்பம் இருக்கிறது.",
            "numberInSurah": 5,
            "juz": 30,
            "manzil": 7,
            "page": 596,
            "ruku": 536,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6096,
            "text": "إِنَّ مَعَ الْعُسْرِ يُسْرًا",
            "tamilTransliteration": "இன்ன ம'அல் 'உஸ்ரி யுஸ்ரா",
            "tamilTranslation": "நிச்சயமாக துன்பத்துடன் இன்பம் இருக்கிறது.",
