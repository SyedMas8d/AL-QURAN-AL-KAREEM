{
    "number": 95,
    "name": "سُورَةُ التِّينِ",
    "englishName": "At-Tin",
    "englishNameTranslation": "The Fig",
    "revelationType": "Meccan",
    "tamilName": "அத்-தீன்",
    "tamilNameTranslation": "அத்தி",
    "revelationTypeTamil": "மக்கீ",
    "numberOfAyahs": 8,
    "ayahs": [
        {
            "number": 6099,
            "text": "وَالتِّينِ وَالزَّيْتُونِ",
            "tamilTransliteration": "வத் தீனி வZஜ் Zஜய்தூன்",
            "tamilTranslation": "அத்தியின் மீதும், ஒலிவத்தின் (ஜைத்தூன்) மீதும் சத்தியமாக",
            "numberInSurah": 1,
            "juz": 30,
            "manzil": 7,
            "page": 597,
            "ruku": 537,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6100,
            "text": "وَطُورِ سِينِينَ",
            "tamilTransliteration": "வ தூரி ஸினீன்",
            "tamilTranslation": "“ஸினாய்” மலையின் மீதும் சத்தியமாக",
            "numberInSurah": 2,
            "juz": 30,
            "manzil": 7,
            "page": 597,
            "ruku": 537,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6101,
            "text": "وَهَٰذَا الْبَلَدِ الْأَمِينِ",
            "tamilTransliteration": "வ ஹாதல் Bபலதில் அமீன்",
            "tamilTranslation": "மேலும் அபயமளிக்கும் இந்த (மக்கமா) நகரத்தின் மீதும் சத்தியமாக",
            "numberInSurah": 3,
            "juz": 30,
            "manzil": 7,
            "page": 597,
            "ruku": 537,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6102,
            "text": "لَقَدْ خَلَقْنَا الْإِنْسَانَ فِي أَحْسَنِ تَقْوِيمٍ",
            "tamilTransliteration": "லகத் கலக்னல் இன்ஸான Fபீ அஹ்ஸனி தக்வீம்",
            "tamilTranslation": "திடமாக, நாம் மனிதனை மிகவும் அழகிய அமைப்பில் படைத்தோம்.",
            "numberInSurah": 4,
            "juz": 30,
            "manzil": 7,
            "page": 597,
            "ruku": 537,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6103,
            "text": "ثُمَّ رَدَدْنَاهُ أَسْفَلَ سَافِلِينَ",
            "tamilTransliteration": "தும்ம ரதத் னாஹு அஸ்Fபல ஸாFபிலீன்",
            "tamilTranslation": "பின்னர் (அவன் செயல்களின் காரணமாக) அவனைத் தாழ்ந்தவர்களில், மிக்க தாழ்ந்தவனாக்கினோம்.",
            "numberInSurah": 5,
            "juz": 30,
            "manzil": 7,
            "page": 597,
            "ruku": 537,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6104,
            "text": "إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ",
            "tamilTransliteration": "இல்ல்-லல் லதீன ஆமனூ வ 'அமிலுஸ் ஸாலிஹாதி; Fபலஹும் அஜ்ருன் கய்ரு மம்னூன்",
            "tamilTranslation": "எவர்கள் நம்பிக்கை கொண்டு நற்செயல்கைளைச் செய்தார்களோ அவர்களுக்கு என்றும் முடிவில்லாத (நற்)கூலியுண்டு.",
            "numberInSurah": 6,
            "juz": 30,
            "manzil": 7,
            "page": 597,
            "ruku": 537,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6105,
            "text": "فَمَا يُكَذِّبُكَ بَعْدُ بِالدِّينِ",
            "tamilTransliteration": "Fபம யு கத் திBபுக Bபஃது Bபித் தீன்",
            "tamilTranslation": "எனவே (இதற்குப்) பின்னர், நியாயத் தீர்ப்பு நாளைப்பற்றி உம்மிடம் எது பொய்யாக்க முடியும்?",
            "numberInSurah": 7,
            "juz": 30,
            "manzil": 7,
            "page": 597,
            "ruku": 537,
            "hizbQuarter": 239,
            "sajda": false
        },
        {
            "number": 6106,
            "text": "أَلَيْسَ اللَّهُ بِأَحْكَمِ الْحَاكِمِينَ",
            "tamilTransliteration": "அலய் ஸல் லாஹு Bபி-அஹ்கமில் ஹாகிமீன்",
            "tamilTranslation": "அல்லாஹ் தீர்ப்புச் செய்வோரில் எல்லாம் மிக மேலாகத் தீர்ப்புச் செய்பவனில்லையா?",
            "numberInSurah": 8,
            "juz": 30,
            "manzil": 7,
            "page": 597,
            "ruku": 537,
            "hizbQuarter": 239,
            "sajda": false
        }
    ]
}
