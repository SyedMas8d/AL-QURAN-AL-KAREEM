    "ayahs": [
        {
            "number": 6208,
            "text": "قُلْ يَا أَيُّهَا الْكَافِرُونَ",
            "tamilTransliteration": "குல் யா-அய்யுஹல் காFபிரூன்",
            "tamilTranslation": "(நபியே!) நீர் சொல்வீராக: காஃபிர்களே!",
            "numberInSurah": 1,
            "juz": 30,
            "manzil": 7,
            "page": 603,
            "ruku": 551,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6209,
            "text": "لَا أَعْبُدُ مَا تَعْبُدُونَ",
            "tamilTransliteration": "லா அஃBபுது மா த்'அBபுதூன்",
            "tamilTranslation": "நீங்கள் வணங்குபவற்றை நான் வணங்கமாட்டேன்.",
            "numberInSurah": 2,
            "juz": 30,
            "manzil": 7,
            "page": 603,
            "ruku": 551,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6210,
            "text": "وَلَا أَنْتُمْ عَابِدُونَ مَا أَعْبُدُ",
            "tamilTransliteration": "வ லா அன்தும் 'ஆBபிதூன மா அஃBபுத்",
            "tamilTranslation": "இன்னும், நான் வணங்குகிறவனை நீங்கள் வணங்குகிறவர்களல்லர்.",
            "numberInSurah": 3,
            "juz": 30,
            "manzil": 7,
            "page": 603,
            "ruku": 551,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6211,
            "text": "وَلَا أَنَا عَابِدٌ مَا عَبَدْتُمْ",
            "tamilTransliteration": "வ லா அன 'அBபிதும் மா 'அBபத்தும்",
            "tamilTranslation": "அன்றியும், நீங்கள் வணங்குபவற்றை நான் வணங்குபவனல்லன்.",
            "numberInSurah": 4,
            "juz": 30,
            "manzil": 7,
            "page": 603,
            "ruku": 551,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
