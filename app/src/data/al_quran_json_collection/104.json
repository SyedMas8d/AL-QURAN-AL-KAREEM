{
    "number": 104,
    "name": "سُورَةُ الهُمَزَةِ",
    "englishName": "Al-Humaza",
    "englishNameTranslation": "The Traducer",
    "revelationType": "Meccan",
    "numberOfAyahs": 9,
    "tamilName": "அல்-ஹுமஜா",
    "tamilNameTranslation": "புறங்கூறல்",
    "revelationTypeTamil": "மக்கீ",
    "ayahs": [
        {
            "number": 6180,
            "text": "وَيْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ",
            "tamilTransliteration": "வய்லுல்-லிகுல்லி ஹு மZஜதில்-லுமZஜஹ்",
            "tamilTranslation": "குறை சொல்லிப் புறம் பேசித் திரியும் ஒவ்வொருவனுக்கும் கேடுதான்.",
            "numberInSurah": 1,
            "juz": 30,
            "manzil": 7,
            "page": 601,
            "ruku": 546,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6181,
            "text": "الَّذِي جَمَعَ مَالًا وَعَدَّدَهُ",
            "tamilTransliteration": "அல்லதீ ஜம'அ மால(ன்)வ் வ 'அத்ததஹ்",
            "tamilTranslation": "(அத்தகையவன் செல்வமே சாசுவதமென எண்ணிப்) பொருளைச் சேகரித்து எண்ணிக் கொண்டே இருக்கின்றான்.",
            "numberInSurah": 2,
            "juz": 30,
            "manzil": 7,
            "page": 601,
            "ruku": 546,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6182,
            "text": "يَحْسَبُ أَنَّ مَالَهُ أَخْلَدَهُ",
            "tamilTransliteration": "யஹ்ஸBபு அன்ன மாலஹூ அக்லதஹ்",
            "tamilTranslation": "நிச்சயமாகத், தன் பொருள் தன்னை (உலகில் நித்தியனாக) என்றும் நிலைத்திருக்கச் செய்யுமென்று அவன் எண்ணுகிறான்.",
            "numberInSurah": 3,
            "juz": 30,
            "manzil": 7,
            "page": 601,
            "ruku": 546,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6183,
            "text": "كَلَّا ۖ لَيُنْبَذَنَّ فِي الْحُطَمَةِ",
            "tamilTransliteration": "கல்லா; லயும்Bபதன்ன Fபில் ஹுதமஹ்",
            "tamilTranslation": "அப்படியல்ல, நிச்சயமாக அவன் ஹுதமாவில் எறியப்படுவான்.",
            "numberInSurah": 4,
            "juz": 30,
            "manzil": 7,
            "page": 601,
            "ruku": 546,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6184,
            "text": "وَمَا أَدْرَاكَ مَا الْحُطَمَةُ",
            "tamilTransliteration": "வமா அத்ராக மல்-ஹுதமஹ்",
            "tamilTranslation": "ஹுதமா என்ன என்பதை உமக்கு அறிவித்தது எது?",
            "numberInSurah": 5,
            "juz": 30,
            "manzil": 7,
            "page": 601,
            "ruku": 546,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6185,
            "text": "نَارُ اللَّهِ الْمُوقَدَةُ",
            "tamilTransliteration": "னாருல் லாஹில்-மூகதா",
            "tamilTranslation": "அது எரிந்து கொண்டிருக்கும் அல்லாஹ்வின் நெருப்பாகும்.",
            "numberInSurah": 6,
            "juz": 30,
            "manzil": 7,
            "page": 601,
            "ruku": 546,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6186,
            "text": "الَّتِي تَطَّلِعُ عَلَى الْأَفْئِدَةِ",
            "tamilTransliteration": "அல்லதீ தத்தலி'உ 'அலல் அFப்'இதஹ்",
            "tamilTranslation": "அது (உடலில் பட்டதும்) இருதயங்களில் பாயும்.",
            "numberInSurah": 7,
            "juz": 30,
            "manzil": 7,
            "page": 601,
            "ruku": 546,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6187,
            "text": "إِنَّهَا عَلَيْهِمْ مُؤْصَدَةٌ",
            "tamilTransliteration": "இன்னஹா 'அலய்ஹிம் மு'ஸதா",
            "tamilTranslation": "நிச்சயமாக அது அவர்களைச் சூழ்ந்து மூட்டப்படும்.",
            "numberInSurah": 8,
            "juz": 30,
            "manzil": 7,
            "page": 601,
            "ruku": 546,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6188,
            "text": "فِي عَمَدٍ مُمَدَّدَةٍ",
            "tamilTransliteration": "Fபீ 'அமதிம் முமத்ததஹ்",
            "tamilTranslation": "நீண்ட கம்பங்களில் (அவர்கள் கட்டப்பட்டவர்களாக).",
            "numberInSurah": 9,
            "juz": 30,
            "manzil": 7,
            "page": 601,
            "ruku": 546,
            "hizbQuarter": 240,
            "sajda": false
        }
    ]
}
