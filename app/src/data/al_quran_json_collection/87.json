{
    "number": 87,
    "name": "سُورَةُ الأَعۡلَىٰ",
    "englishName": "Al-A'laa",
    "englishNameTranslation": "The Most High",
    "revelationType": "Meccan",
    "numberOfAyahs": 19,
    "tamilName": "அல்-அஃலா",
    "tamilNameTranslation": "மிக்க மேலானவன்",
    "revelationTypeTamil": "மக்கீ",
    "ayahs": [
        {
            "number": 5949,
            "text": "سَبِّحِ اسْمَ رَبِّكَ الْأَعْلَى",
            "tamilTransliteration": "ஸBப்Bபிஹிஸ்ம ரBப்Bபிகல் அஃலா",
            "tamilTranslation": "(நபியே!) மிக்க மேலானவனான உம்முடைய இறைவனின் திருநாமத்தை(த் தியானித்து) தஸ்பீஹு செய்வீராக.",
            "numberInSurah": 1,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5950,
            "text": "الَّذِي خَلَقَ فَسَوَّىٰ",
            "tamilTransliteration": "அல்லதீ கலக Fபஸவ்வா",
            "tamilTranslation": "அவனே (யாவற்றையும்) படைத்துச் செவ்வையாக்கினான்.",
            "numberInSurah": 2,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5951,
            "text": "وَالَّذِي قَدَّرَ فَهَدَىٰ",
            "tamilTransliteration": "வல்லதீ கத்தர Fபஹதா",
            "tamilTranslation": "மேலும், அவனே (அவற்றுக்கு வேண்டிய அனைத்தையும்) அளவுபட நிர்ணயித்து (அவற்றைப் பெறுவதற்கு) நேர்வழி காட்டினான்.",
            "numberInSurah": 3,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5952,
            "text": "وَالَّذِي أَخْرَجَ الْمَرْعَىٰ",
            "tamilTransliteration": "வல்லதீ அக்ரஜல் மர்'ஆ",
            "tamilTranslation": "அன்றியும் அவனே (கால் நடைகளுக்கென) மேய்ச்சலுக்குரியவற்றையும் வெளியாக்கினான்.",
            "numberInSurah": 4,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5953,
            "text": "فَجَعَلَهُ غُثَاءً أَحْوَىٰ",
            "tamilTransliteration": "Fபஜ'அலஹூ குதா'அன் அஹ்வா",
            "tamilTranslation": "பின்னர் அவற்றை உலர்ந்த கூளங்களாக ஆக்கினான்.",
            "numberInSurah": 5,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5954,
            "text": "سَنُقْرِئُكَ فَلَا تَنْسَىٰ",
            "tamilTransliteration": "ஸனுக்ரி'உக Fபலா தன்ஸா",
            "tamilTranslation": "(நபியே!) நாம் உமக்கு ஓதக்கற்றுக் கொடுப்போம்; அதனால் நீர் அதை மறக்கமாட்டீர்-",
            "numberInSurah": 6,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5955,
            "text": "إِلَّا مَا شَاءَ اللَّهُ ۚ إِنَّهُ يَعْلَمُ الْجَهْرَ وَمَا يَخْفَىٰ",
            "tamilTransliteration": "இல்லா மா ஷா'அல் லாஹ்; இன்னஹூ யஃலமுல் ஜஹ்ர வமா யக்Fபா",
            "tamilTranslation": "அல்லாஹ் நாடியதை அல்லாமல்; நிச்சயமாக, அவன் வெளிப்படையானதையும் மறைந்திருப்பதையும் அறிகிறான்.",
            "numberInSurah": 7,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5956,
            "text": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
            "tamilTransliteration": "வ னு-யஸ்ஸிருக லில்யுஸ்ரா",
            "tamilTranslation": "அன்றியும், இலேசான (மார்க்கத்)தை நாம் உமக்கு எளிதாக்குவோம்.",
            "numberInSurah": 8,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5957,
            "text": "فَذَكِّرْ إِنْ نَفَعَتِ الذِّكْرَىٰ",
            "tamilTransliteration": "Fபதக்கிர் இன் னFப'அதித்திக்ரா",
            "tamilTranslation": "ஆகவே, நல்லுபதேசம் பயனளிக்குமாயின், நீர் உபதேசம் செய்வீராக.",
            "numberInSurah": 9,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5958,
            "text": "سَيَذَّكَّرُ مَنْ يَخْشَىٰ",
            "tamilTransliteration": "ஸ யத்தக்கரு மய்யக்-ஷா",
            "tamilTranslation": "(அல்லாஹ்வுக்கு) அஞ்சுபவன் விரைவில் உபதேசத்தை ஏற்பான்.",
            "numberInSurah": 10,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5959,
            "text": "وَيَتَجَنَّبُهَا الْأَشْقَى",
            "tamilTransliteration": "வ யதஜன்னBபுஹல் அஷ்கா",
            "tamilTranslation": "ஆனால் துர்பாக்கியமுடையவனோ, அதை விட்டு விலகிக் கொள்வான்.",
            "numberInSurah": 11,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5960,
            "text": "الَّذِي يَصْلَى النَّارَ الْكُبْرَىٰ",
            "tamilTransliteration": "அல்லதீ யஸ்லன் னாரல் குBப்ரா",
            "tamilTranslation": "அவன் தான் பெரும் நெருப்பில் புகுவான்.",
            "numberInSurah": 12,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5961,
            "text": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
            "tamilTransliteration": "தும்ம லா யமூது Fபீஹா வலா யஹ்யா",
            "tamilTranslation": "பின்னர், அதில் அவன் மரணிக்கவும் மாட்டான்; வாழவும் மாட்டான்.",
            "numberInSurah": 13,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5962,
            "text": "قَدْ أَفْلَحَ مَنْ تَزَكَّىٰ",
            "tamilTransliteration": "கத் அFப்லஹ மன் தZஜக்கா",
            "tamilTranslation": "தூய்மையடைந்தவன், திட்டமாக வெற்றி பெறுகிறான்.",
            "numberInSurah": 14,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5963,
            "text": "وَذَكَرَ اسْمَ رَبِّهِ فَصَلَّىٰ",
            "tamilTransliteration": "வ தகரஸ் ம ரBப்Bபிஹீ Fபஸல்லா",
            "tamilTranslation": "மேலும், அவன் தன் இறைவனுடைய நாமத்தைத் துதித்துக் கொண்டும், தொழுது கொண்டும் இருப்பான்.",
            "numberInSurah": 15,
            "juz": 30,
            "manzil": 7,
            "page": 591,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5964,
            "text": "بَلْ تُؤْثِرُونَ الْحَيَاةَ الدُّنْيَا",
            "tamilTransliteration": "Bபல் து'திரூனல் ஹயாதத் துன்யா",
            "tamilTranslation": "எனினும், நீங்களோ (மறுமையை விட்டு விட்டு) இவ்வுலக வாழ்வைத் தேர்ந்தெடுத்துக் கொள்கிறீர்கள்.",
            "numberInSurah": 16,
            "juz": 30,
            "manzil": 7,
            "page": 592,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5965,
            "text": "وَالْآخِرَةُ خَيْرٌ وَأَبْقَىٰ",
            "tamilTransliteration": "வல் ஆகிரது கய்ரு(ன்)வ் வ அBப்கா",
            "tamilTranslation": "ஆனால் மறுமை (வாழ்க்கை)யோ சிறந்ததாகும்; என்றும் நிலைத்திருப்பதும் ஆகும்.",
            "numberInSurah": 17,
            "juz": 30,
            "manzil": 7,
            "page": 592,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5966,
            "text": "إِنَّ هَٰذَا لَفِي الصُّحُفِ الْأُولَىٰ",
            "tamilTransliteration": "இன்ன ஹாதா லFபிஸ் ஸுஹு Fபில் ஊலா",
            "tamilTranslation": "நிச்சயமாக இது முந்திய ஆகமங்களிலும்-",
            "numberInSurah": 18,
            "juz": 30,
            "manzil": 7,
            "page": 592,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        },
        {
            "number": 5967,
            "text": "صُحُفِ إِبْرَاهِيمَ وَمُوسَىٰ",
            "tamilTransliteration": "ஸுஹுFபி இBப்ராஹீம வ மூஸா",
            "tamilTranslation": "இப்ராஹீம், மூஸாவினுடைய ஆகமங்களிலும் (இவ்வாறே அறிவிப்பு) இருக்கிறது.",
            "numberInSurah": 19,
            "juz": 30,
            "manzil": 7,
            "page": 592,
            "ruku": 529,
            "hizbQuarter": 237,
            "sajda": false
        }
    ]
}
