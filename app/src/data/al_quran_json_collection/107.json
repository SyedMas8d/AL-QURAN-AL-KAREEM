{
    "number": 107,
    "name": "سُورَةُ المَاعُونِ",
    "englishName": "Al-Maa'un",
    "englishNameTranslation": "Almsgiving",
    "revelationType": "Meccan",
    "numberOfAyahs": 7,
    "tamilName": "அல்-மாஊன்",
    "tamilNameTranslation": "அற்பப் பொருட்கள்",
    "revelationTypeTamil": "மக்கீ",
    "ayahs": [
        {
            "number": 6198,
            "text": "أَرَأَيْتَ الَّذِي يُكَذِّبُ بِالدِّينِ",
            "tamilTransliteration": "அர 'அய்தல் லதீ யுகத்திBபு Bபித்தீன்",
            "tamilTranslation": "(நபியே!) நியாயத் தீர்ப்பைப் பொய்ப்பிக்கின்றானே அவனை நீர் பார்த்தீரா?",
            "numberInSurah": 1,
            "juz": 30,
            "manzil": 7,
            "page": 602,
            "ruku": 549,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6199,
            "text": "فَذَٰلِكَ الَّذِي يَدُعُّ الْيَتِيمَ",
            "tamilTransliteration": "Fபதாலிகல் லதீ யது'உல்-யதீம்",
            "tamilTranslation": "பின்னர் அவன்தான் அநாதைகளை விரட்டுகிறான்.",
            "numberInSurah": 2,
            "juz": 30,
            "manzil": 7,
            "page": 602,
            "ruku": 549,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6200,
            "text": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ الْمِسْكِينِ",
            "tamilTransliteration": "வ ல யஹுள்ளு 'அலா த'ஆமில் மிஸ்கீன்",
            "tamilTranslation": "மேலும், ஏழைக்கு உணவளிப்பதின் பேரிலும் அவன் தூண்டுவதில்லை.",
            "numberInSurah": 3,
            "juz": 30,
            "manzil": 7,
            "page": 602,
            "ruku": 549,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6201,
            "text": "فَوَيْلٌ لِلْمُصَلِّينَ",
            "tamilTransliteration": "Fப வய்லுல்-லில் முஸல்லீன்",
            "tamilTranslation": "இன்னும், (கவனமற்ற) தொழுகையாளிகளுக்குக் கேடுதான்.",
            "numberInSurah": 4,
            "juz": 30,
            "manzil": 7,
            "page": 602,
            "ruku": 549,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6202,
            "text": "الَّذِينَ هُمْ عَنْ صَلَاتِهِمْ سَاهُونَ",
            "tamilTransliteration": "அல்லதீன ஹும் 'அன் ஸலாதிஹிம் ஸாஹூன்",
            "tamilTranslation": "அவர்கள் எத்தகையோர் என்றால் தம் தொழுகையில் பராமுகமாக(வும், அசிரத்தையாக)வும் இருப்போர்.",
            "numberInSurah": 5,
            "juz": 30,
            "manzil": 7,
            "page": 602,
            "ruku": 549,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6203,
            "text": "الَّذِينَ هُمْ يُرَاءُونَ",
            "tamilTransliteration": "அல்லதீன ஹும் யுரா'ஊன்",
            "tamilTranslation": "அவர்கள் பிறருக்குக் காண்பிக்(கவே தான் தொழு)கிறார்கள்.",
            "numberInSurah": 6,
            "juz": 30,
            "manzil": 7,
            "page": 602,
            "ruku": 549,
            "hizbQuarter": 240,
            "sajda": false
        },
        {
            "number": 6204,
            "text": "وَيَمْنَعُونَ الْمَاعُونَ",
            "tamilTransliteration": "வ யம்ன'ஊனல் மா'ஊன்",
            "tamilTranslation": "மேலும், அற்பமான (புழங்கும்) பொருள்களைக் (கொடுப்பதை விட்டும்) தடுக்கிறார்கள்.",
            "numberInSurah": 7,
            "juz": 30,
            "manzil": 7,
            "page": 602,
            "ruku": 549,
            "hizbQuarter": 240,
            "sajda": false
        }
    ]
}
